        "jsonBody": "={{ JSON.stringify({ model: 'llama-3.3-70b-versatile', temperature: 0, max_tokens: 300, response_format: { type: 'json_object' }, messages: $json.messages }) }}",
        "options": {}
      },
      "id": "503c1ef7-deac-43cd-b70f-63c415e627ba",
      "name": "AI — Analyze Article",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
