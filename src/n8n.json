    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const item = $input.item.json;\n\nconst title = (item.title || '').trim();\nconst sourceName = item.source_name || 'Unknown';\nconst content = (item.content || '').substring(0, 1500).trim();\n\nconst systemPrompt =  'You are a tech news analyst. Return a JSON object with exactly these three fields: category, summary, importance_score. Category MUST be one of these values only: AI, Startups, Cybersecurity, Cloud, Software Engineering, Mobile, Data Science, Business Tech, Other. Do not invent new categories. Respond ONLY with valid JSON. No markdown. No explanation.';\n\nconst userPrompt = 'Title: ' + title + '\\nSource: ' + sourceName + '\\n\\nContent:\\n' + content + '\\n\\nAnalyze this article.';\n\nreturn {\n  json: {\n    _articleId: item.id,\n    messages: [\n      { role: 'system', content: systemPrompt },\n      { role: 'user', content: userPrompt }\n    ]\n  }\n};"
      },
