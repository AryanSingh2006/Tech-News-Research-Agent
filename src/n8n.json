    {
      "parameters": {
        "jsCode": "const groqResponse = $input.first().json;\nconst promptData = $node['Build Report Prompt'].json;\n\nconst rawReport = groqResponse.choices?.[0]?.message?.content || '';\n\nif (!rawReport) {\n  throw new Error('Groq returned an empty response.');\n}\n\nconst today = promptData._today;\nconst articleCount = promptData._articleCount;\nconst categories = promptData._categories;\n\n// ── Discord markdown formatting ──────────────────────────────────────────────\nconst discordReport =\n  `📰 **Tech Daily Briefing — ${today}**\\n` +\n  `*${articleCount} articles analysed across: ${categories}*\\n\\n` +\n  rawReport\n    .replace(/## Executive Summary/g, '**📋 Executive Summary**')\n    .replace(/## Top Stories/g, '**🔥 Top Stories**')\n    .replace(/## Key Trends/g, '**📈 Key Trends**')\n    .replace(/## Categories Covered/g, '**🗂️ Categories Covered**')\n    .trim();\n\n// Discord has a 2000-char limit per message; truncate if needed\nconst discordFinal = discordReport.length > 1950\n  ? discordReport.substring(0, 1947) + '...'\n  : discordReport;\n\n// ── HTML email formatting ────────────────────────────────────────────────────\nconst htmlBody = `<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Tech Daily Briefing — ${today}</title>\n<style>\n  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif; background: #f4f6f9; margin: 0; padding: 24px; color: #1a1a2e; }\n  .wrapper { max-width: 640px; margin: 0 auto; }\n  .header { background: #1a1a2e; border-radius: 10px 10px 0 0; padding: 28px 32px; }\n  .header h1 { color: #ffffff; font-size: 22px; font-weight: 600; margin: 0 0 6px; }\n  .header p { color: #a0aec0; font-size: 13px; margin: 0; }\n  .body { background: #ffffff; padding: 32px; }\n  .section { margin-bottom: 28px; }\n  .section h2 { font-size: 15px; font-weight: 600; color: #2d3748; text-transform: uppercase; letter-spacing: 0.06em; border-left: 3px solid #5a67d8; padding-left: 10px; margin: 0 0 14px; }\n  .section p, .section li { font-size: 14px; line-height: 1.7; color: #4a5568; margin: 0 0 10px; }\n  .section ul { padding-left: 20px; margin: 0; }\n  .footer { background: #f4f6f9; border-radius: 0 0 10px 10px; padding: 16px 32px; text-align: center; }\n  .footer p { font-size: 12px; color: #718096; margin: 0; }\n  strong { color: #2d3748; }\n</style>\n</head>\n<body>\n<div class=\"wrapper\">\n  <div class=\"header\">\n    <h1>Tech Daily Briefing</h1>\n    <p>${today} &nbsp;·&nbsp; ${articleCount} articles analysed &nbsp;·&nbsp; ${categories}</p>\n  </div>\n  <div class=\"body\">\n    ${rawReport\n      .replace(/## Executive Summary/g, '<div class=\"section\"><h2>Executive Summary</h2>')\n      .replace(/## Top Stories/g, '</div><div class=\"section\"><h2>Top Stories</h2>')\n      .replace(/## Key Trends/g, '</div><div class=\"section\"><h2>Key Trends</h2>')\n      .replace(/## Categories Covered/g, '</div><div class=\"section\"><h2>Categories Covered</h2>')\n      .replace(/\\*\\*(.+?)\\*\\*/g, '<strong>$1</strong>')\n      .replace(/^- (.+)$/gm, '<li>$1</li>')\n      .replace(/(<li>.*<\\/li>\\n?)+/gs, match => `<ul>${match}</ul>`)\n      .replace(/\\n\\n/g, '</p><p>')\n      .replace(/^(?!<)/gm, '')\n    }\n  </div>\n  </div>\n  <div class=\"footer\">\n    <p>Generated automatically by your Tech News Research Agent</p>\n  </div>\n</div>\n</body>\n</html>`;\n\nreturn [\n  {\n    json: {\n      discord_message: discordFinal,\n      email_subject: `Tech Daily Briefing — ${today}`,\n      email_html: htmlBody,\n      report_date: today,\n      article_count: articleCount\n    }\n  }\n];"
      },
