        "query": "SELECT\n  id,\n  title,\n  source_name,\n  category,\n  summary,\n  importance_score,\n  url,\n  published_at\nFROM articles\nWHERE\n  processed = true\n  AND created_at >= NOW() - INTERVAL '24 hours'\n  AND summary IS NOT NULL\n  AND LENGTH(summary) > 20\nORDER BY importance_score DESC\nLIMIT 10;",
